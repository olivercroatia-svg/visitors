# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
COOKIE_SECURE=false

# Database (MySQL / aaPanel on Hetzner in prod)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=visitors_dev

# Fiscalization (F1 — računi u krajnjoj potrošnji).
# `mock` = no certificate needed. `fina` = talk to the tax authority's CIS directly.
FISCAL_PROVIDER=mock
FISCAL_TEST_URL=https://cistest.apis-it.hr:8449/FiskalizacijaServiceTest
FISCAL_PROD_URL=https://cis.porezna-uprava.hr:8449/FiskalizacijaService
# The v2.7 spec prints XML-DSig algorithm URIs that do not exist in the W3C registry.
# We send the standard ones. Set this to true only if the service rejects them (error s004).
FISCAL_XMLDSIG_SPEC_URIS=false

# eVisitor (HTZ) — mock until real API credentials exist, then `http`.
EVISITOR_PROVIDER=mock
EVISITOR_TEST_URL=https://www.evisitor.hr/testApi
EVISITOR_PROD_URL=https://www.evisitor.hr/eVisitorRhetos_API
# How often the retry queue is drained (minutes). Check-ins have a 24h legal window.
EVISITOR_QUEUE_INTERVAL_MIN=5

# Encrypts at rest everything we must read back: eVisitor passwords AND the fiscal
# signing certificate (.p12). 32 bytes hex: openssl rand -hex 32
# REQUIRED in production, and whenever FISCAL_PROVIDER or EVISITOR_PROVIDER is not `mock`.
# Back it up with the database — without it, credentials and the certificate must be
# re-uploaded. Never commit it.
SECRETS_ENC_KEY=
