# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
COOKIE_SECURE=false

# Database (MySQL / aaPanel on Hetzner in prod)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=visitors_dev

# Fiscalization provider (mock during development)
FISCAL_PROVIDER=mock

# eVisitor (HTZ) — mock until real API credentials exist, then `http`.
EVISITOR_PROVIDER=mock
EVISITOR_TEST_URL=https://www.evisitor.hr/testApi
EVISITOR_PROD_URL=https://www.evisitor.hr/eVisitorRhetos_API
# Encrypts per-tenant eVisitor passwords at rest. 32 bytes hex: openssl rand -hex 32
# REQUIRED whenever EVISITOR_PROVIDER is not `mock`, and always in production.
# Back it up with the database — without it, stored credentials must be re-entered.
EVISITOR_ENC_KEY=
# How often the retry queue is drained (minutes). Check-ins have a 24h legal window.
EVISITOR_QUEUE_INTERVAL_MIN=5
