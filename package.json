{
  "name": "visitors",
  "version": "0.1.0",
  "private": true,
  "description": "Visitors — SaaS za račune, fiskalizaciju i financijsku zaštitu malih iznajmljivača (HR)",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w client && npm run build -w server",
    "migrate": "npm run migrate -w server",
    "start": "npm run start -w server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
